# FastAPI Configuration
ENVIRONMENT=development
DEBUG=True
API_HOST=0.0.0.0
API_PORT=8000

# Supabase Configuration (Required)
# Get these from your Supabase project settings: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_SERVICE_KEY=your_supabase_service_key

# OpenAI Configuration (Required)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-2024-11-20
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Document Processing
MAX_FILE_SIZE_MB=10
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# CORS Configuration (Update with your frontend URL for production)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Security (Strongly recommended for production)
# Generate a secure API key with: openssl rand -hex 32
# When set, all API endpoints except /health will require X-API-Key header
# API_KEY=your-secure-random-api-key-here

# Logging
LOG_LEVEL=INFO
